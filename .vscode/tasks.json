{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar proyecto",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "main.cpp",
                "grafo.cpp",
                "reto_1.cpp",
                "reto_2.cpp",
                "reto_3.cpp",
                "reto_4.cpp",
                "reto_5.cpp",
                "-o",
                "main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}/src"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
